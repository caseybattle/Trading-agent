{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "cronSchedule": "*/30 * * * *",
    "startCommand": "python scripts/kalshi_btc_trader.py --once --auto-trade",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
