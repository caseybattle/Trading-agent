# Copy this file to .env and fill in your keys

# Required for Kalshi data collection
KALSHI_API_KEY=your_kalshi_api_key_here

# Optional: LLM strategy (uses OpenAI-compatible endpoint)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Hyperliquid delta-neutral hedging
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_API_SECRET=your_hyperliquid_api_secret_here
