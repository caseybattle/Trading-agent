# Copy this file to .env and fill in your values

# Kalshi RSA auth — required for live trading
KALSHI_API_KEY_ID=your_api_key_id_here
KALSHI_USE_DEMO=false

# Private key: use file path for local dev, contents for cloud/Railway
KALSHI_PRIVATE_KEY_PATH=/app/kalshi_private_key.pem
# KALSHI_PRIVATE_KEY_CONTENTS=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Optional: AWS S3 storage backend (local file I/O used if unset)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=

# Optional: LLM strategy (OpenAI-compatible endpoint)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Hyperliquid delta-neutral hedging
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
HYPERLIQUID_API_SECRET=your_hyperliquid_api_secret_here
